# Flask Application Settings
FLASK_SECRET_KEY=super_secret_key_for_flash_messages

# Supabase Production Database & Auth Credentials
SUPABASE_URL=https://iojtglaxgdwsxxalhubx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlvanRnbGF4Z2R3c3h4YWxodWJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc1NjgzNTIsImV4cCI6MjA5MzE0NDM1Mn0.KA7wdsZsK3oA6ybi5Gl_KnkzAKZM-ESI3Eyzx-mipwM
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_here
# JWT Secret của project (Supabase Dashboard -> Settings -> API -> JWT Secret).
# Dùng để ký token ngắn hạn chứa business_id cho các trang gọi Supabase trực tiếp từ trình duyệt (RLS tenant isolation).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# DeepSeek AI Studio API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Bí mật xác thực cho Vercel Cron Job (/api/cron/daily_tasks) — tự đặt 1 chuỗi ngẫu nhiên mạnh.
# Vercel tự động gửi header "Authorization: Bearer <CRON_SECRET>" khi cron chạy nếu biến này
# được cấu hình trong Vercel Project Settings -> Environment Variables.
CRON_SECRET=your_random_cron_secret_here

# Tuỳ chọn: để gửi thông báo Loyalty (tích điểm/lên hạng/sinh nhật) THẬT qua Zalo OA / Facebook
# Messenger. Chưa điền thì hệ thống chỉ ghi lại (queued), không gửi đi đâu — không lỗi gì cả.
ZALO_OA_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=
