# =========================================================================
# BitPaw SaaS Multitenant Platform Environment Variables Configuration
# Copy this file to '.env' and populate the keys for production deployment.
# =========================================================================

# Flask Application Settings — BẮT BUỘC, app sẽ raise lỗi và không khởi động nếu thiếu.
# Tự sinh 1 chuỗi ngẫu nhiên mạnh, không dùng lại giá trị mẫu này.
FLASK_SECRET_KEY=your_random_flask_secret_key_here

# MongoDB Atlas — đang thay thế dần Supabase (xem mongo_client.py). BẮT BUỘC cho Auth
# (register/login/logout) và các phần đã migrate; database mặc định là "bitpaw_db".
# Connection string dạng: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_URI=your_mongodb_atlas_connection_string_here

# Supabase Production Database & Auth Credentials — vẫn BẮT BUỘC cho tới khi migrate xong toàn bộ
# 33 bảng còn lại (xem tiến độ migration MongoDB). Không còn fallback hardcode trong code nữa.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_here
# JWT Secret của project (Supabase Dashboard -> Settings -> API -> JWT Secret).
# Dùng để ký token ngắn hạn chứa business_id cho các trang gọi Supabase trực tiếp từ trình duyệt (RLS tenant isolation).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# DeepSeek AI Studio API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Bí mật xác thực cho Vercel Cron Job (/api/cron/daily_tasks) — tự đặt 1 chuỗi ngẫu nhiên mạnh.
# Vercel tự động gửi header "Authorization: Bearer <CRON_SECRET>" khi cron chạy nếu biến này
# được cấu hình trong Vercel Project Settings -> Environment Variables.
CRON_SECRET=your_random_cron_secret_here

# Tuỳ chọn: để gửi thông báo Loyalty (tích điểm/lên hạng/sinh nhật) THẬT qua Zalo OA / Facebook
# Messenger. Chưa điền thì hệ thống chỉ ghi lại (queued), không gửi đi đâu — không lỗi gì cả.
ZALO_OA_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=

# US Market — Square Sandbox payment gateway (chỉ dùng cho tenant country == 'US').
# Lấy sandbox access token + location id tại https://developer.squareup.com/apps (Sandbox tab).
# Chưa điền thì /api/us-payment/start trả về lỗi rõ ràng "chưa cấu hình", không crash server.
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# Tuỳ chọn: ID máy Square Terminal vật lý đã pair với tenant. Để trống = dùng Payment Link
# (hosted checkout link, không cần phần cứng) thay vì đẩy checkout ra máy quẹt thẻ thật.
SQUARE_DEVICE_ID=

# Danh sách email (cách nhau bởi dấu phẩy) được phép truy cập /super_admin và các API superadmin
# (/api/superadmin/duc_ma, /api/superadmin/get_keys). Để trống = không ai truy cập được (mặc định an toàn).
SUPERADMIN_EMAILS=owner1@yourcompany.com,owner2@yourcompany.com

# Gmail SMTP — dùng để gửi email tự động (xem email_service.py, test tại POST /api/test-email).
# GMAIL_USERNAME: địa chỉ Gmail đầy đủ dùng để gửi (vd: yourshop@gmail.com).
# GMAIL_APP_PASSWORD: KHÔNG dùng mật khẩu Gmail thông thường. Phải tạo "App Password" 16 ký tự:
#   1. Bật xác thực 2 bước (2-Step Verification) cho tài khoản Google tại https://myaccount.google.com/security
#   2. Vào https://myaccount.google.com/apppasswords, tạo App Password mới cho "Mail"
#   3. Dán chuỗi 16 ký tự (không dấu cách) vào biến này
# Chưa điền thì API test email trả lỗi rõ ràng "chưa cấu hình", không crash server.
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
